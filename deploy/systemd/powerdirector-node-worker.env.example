# Copy to: /etc/default/powerdirector-node-worker
# Required for most installs:
NODE_WORKER_TOKEN=replace-with-node-host-token

# Optional overrides:
# NODE_WORKER_API_MODE=node-host
# NODE_WORKER_BASE_URL=http://127.0.0.1:18790
# NODE_WORKER_NODE_ID=linux-node-01
# NODE_WORKER_NAME=Linux Node 01
# NODE_WORKER_PLATFORM=linux
# NODE_WORKER_VERSION=1.0.0
# NODE_WORKER_CAPABILITIES=shell
# NODE_WORKER_HEARTBEAT_MS=10000
# NODE_WORKER_POLL_WAIT_MS=5000
# NODE_WORKER_RETRY_DELAY_MS=2000
# NODE_WORKER_ALLOW_SHELL=true
# NODE_WORKER_SHELL_TIMEOUT_MS=15000
