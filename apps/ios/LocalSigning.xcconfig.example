// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

POWERDIRECTOR_CODE_SIGN_STYLE = Automatic
POWERDIRECTOR_DEVELOPMENT_TEAM = YOUR_TEAM_ID

POWERDIRECTOR_APP_BUNDLE_ID = ai.powerdirector.client
POWERDIRECTOR_SHARE_BUNDLE_ID = ai.powerdirector.client.share
POWERDIRECTOR_ACTIVITY_WIDGET_BUNDLE_ID = ai.powerdirector.client.activitywidget
POWERDIRECTOR_WATCH_APP_BUNDLE_ID = ai.powerdirector.client.watchkitapp
POWERDIRECTOR_WATCH_EXTENSION_BUNDLE_ID = ai.powerdirector.client.watchkitapp.extension

// Leave empty with automatic signing.
POWERDIRECTOR_APP_PROFILE =
POWERDIRECTOR_SHARE_PROFILE =
