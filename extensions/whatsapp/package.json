{
  "name": "@powerdirector/whatsapp",
  "version": "2026.3.14",
  "description": "PowerDirector WhatsApp channel plugin",
  "type": "module",
  "dependencies": {
    "@whiskeysockets/baileys": "7.0.0-rc.9"
  },
  "powerdirector": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "whatsapp",
      "label": "WhatsApp",
      "selectionLabel": "WhatsApp (QR link)",
      "detailLabel": "WhatsApp Web",
      "docsPath": "/channels/whatsapp",
      "docsLabel": "whatsapp",
      "blurb": "works with your own number; recommend a separate phone + eSIM.",
      "systemImage": "message"
    },
    "install": {
      "npmSpec": "@powerdirector/whatsapp",
      "localPath": "extensions/whatsapp",
      "defaultChoice": "npm"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
